  "triggers": [
    {
      "name": "trg_users_ad",
      "table": "users",
      "sql": "CREATE TRIGGER trg_users_ad AFTER DELETE ON \"users\" WHEN COALESCE((SELECT apply_mode FROM _sync_apply_state WHERE singleton_key = 1), 0) = 0 BEGIN INSERT INTO _sync_dirty_rows(schema_name, table_name, key_json, op, base_row_version, payload, dirty_ordinal, updated_at) VALUES ( 'main', 'users', json_object('id', OLD.\"id\"), 'DELETE', COALESCE( (SELECT base_row_version FROM _sync_dirty_rows WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', OLD.\"id\")), (SELECT row_version FROM _sync_row_state WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', OLD.\"id\")), 0 ), NULL, COALESCE( (SELECT dirty_ordinal FROM _sync_dirty_rows WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', OLD.\"id\")), (SELECT COALESCE(MAX(dirty_ordinal), 0) + 1 FROM _sync_dirty_rows) ), strftime('%Y-%m-%dT%H:%M:%fZ','now') ) ON CONFLICT(schema_name, table_name, key_json) DO UPDATE SET op='DELETE', payload=NULL, updated_at=excluded.updated_at; END"
    },
    {
      "name": "trg_users_ai",
      "table": "users",
      "sql": "CREATE TRIGGER trg_users_ai AFTER INSERT ON \"users\" WHEN COALESCE((SELECT apply_mode FROM _sync_apply_state WHERE singleton_key = 1), 0) = 0 BEGIN INSERT INTO _sync_dirty_rows(schema_name, table_name, key_json, op, base_row_version, payload, dirty_ordinal, updated_at) VALUES ( 'main', 'users', json_object('id', NEW.\"id\"), CASE WHEN EXISTS ( SELECT 1 FROM _sync_row_state WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', NEW.\"id\") AND deleted=0 ) THEN 'UPDATE' ELSE 'INSERT' END, COALESCE( (SELECT base_row_version FROM _sync_dirty_rows WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', NEW.\"id\")), (SELECT row_version FROM _sync_row_state WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', NEW.\"id\")), 0 ), json_object('id', NEW.\"id\", 'name', NEW.\"name\"), COALESCE( (SELECT dirty_ordinal FROM _sync_dirty_rows WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', NEW.\"id\")), (SELECT COALESCE(MAX(dirty_ordinal), 0) + 1 FROM _sync_dirty_rows) ), strftime('%Y-%m-%dT%H:%M:%fZ','now') ) ON CONFLICT(schema_name, table_name, key_json) DO UPDATE SET op=excluded.op, payload=excluded.payload, updated_at=excluded.updated_at; END"
    },
    {
      "name": "trg_users_au",
      "table": "users",
      "sql": "CREATE TRIGGER trg_users_au AFTER UPDATE ON \"users\" WHEN COALESCE((SELECT apply_mode FROM _sync_apply_state WHERE singleton_key = 1), 0) = 0 BEGIN INSERT INTO _sync_dirty_rows(schema_name, table_name, key_json, op, base_row_version, payload, dirty_ordinal, updated_at) SELECT 'main', 'users', json_object('id', OLD.\"id\"), 'DELETE', COALESCE( (SELECT base_row_version FROM _sync_dirty_rows WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', OLD.\"id\")), (SELECT row_version FROM _sync_row_state WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', OLD.\"id\")), 0 ), NULL, COALESCE( (SELECT dirty_ordinal FROM _sync_dirty_rows WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', OLD.\"id\")), (SELECT COALESCE(MAX(dirty_ordinal), 0) + 1 FROM _sync_dirty_rows) ), strftime('%Y-%m-%dT%H:%M:%fZ','now') WHERE json_object('id', OLD.\"id\") != json_object('id', NEW.\"id\") ON CONFLICT(schema_name, table_name, key_json) DO UPDATE SET op='DELETE', payload=NULL, updated_at=excluded.updated_at; INSERT INTO _sync_dirty_rows(schema_name, table_name, key_json, op, base_row_version, payload, dirty_ordinal, updated_at) VALUES ( 'main', 'users', json_object('id', NEW.\"id\"), CASE WHEN EXISTS ( SELECT 1 FROM _sync_row_state WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', NEW.\"id\") AND deleted=0 ) THEN 'UPDATE' ELSE 'INSERT' END, COALESCE( (SELECT base_row_version FROM _sync_dirty_rows WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', NEW.\"id\")), (SELECT row_version FROM _sync_row_state WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', NEW.\"id\")), 0 ), json_object('id', NEW.\"id\", 'name', NEW.\"name\"), COALESCE( (SELECT dirty_ordinal FROM _sync_dirty_rows WHERE schema_name='main' AND table_name='users' AND key_json=json_object('id', NEW.\"id\")), (SELECT COALESCE(MAX(dirty_ordinal), 0) + 1 FROM _sync_dirty_rows) ), strftime('%Y-%m-%dT%H:%M:%fZ','now') ) ON CONFLICT(schema_name, table_name, key_json) DO UPDATE SET op=excluded.op, payload=excluded.payload, updated_at=excluded.updated_at; END"
