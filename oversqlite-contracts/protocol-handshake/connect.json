{
  "formatVersion": 1,
  "contractCases": [
    {
      "name": "exact-match",
      "localSpecs": [
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]},
        {"schema": "business", "table": "projects", "sync_key_columns": ["project_id"]}
      ],
      "advertised": [
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]},
        {"schema": "business", "table": "projects", "sync_key_columns": ["project_id"]}
      ],
      "expected": {"kind": "match"}
    },
    {
      "name": "reordered-match",
      "localSpecs": [
        {"schema": "business", "table": "projects", "sync_key_columns": ["project_id"]},
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]}
      ],
      "advertised": [
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]},
        {"schema": "business", "table": "projects", "sync_key_columns": ["project_id"]}
      ],
      "expected": {"kind": "match"}
    },
    {
      "name": "server-only",
      "localSpecs": [
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]}
      ],
      "advertised": [
        {"schema": "business", "table": "monitoring_focus", "sync_key_columns": ["id"]},
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]}
      ],
      "expected": {
        "kind": "mismatch",
        "serverOnlyTables": ["business.monitoring_focus"],
        "clientOnlyTables": [],
        "syncKeyMismatches": []
      }
    },
    {
      "name": "client-only",
      "localSpecs": [
        {"schema": "business", "table": "projects", "sync_key_columns": ["project_id"]},
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]}
      ],
      "advertised": [
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]}
      ],
      "expected": {
        "kind": "mismatch",
        "serverOnlyTables": [],
        "clientOnlyTables": ["business.projects"],
        "syncKeyMismatches": []
      }
    },
    {
      "name": "key-mismatch",
      "localSpecs": [
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]}
      ],
      "advertised": [
        {"schema": "business", "table": "users", "sync_key_columns": ["user_id"]}
      ],
      "expected": {
        "kind": "mismatch",
        "serverOnlyTables": [],
        "clientOnlyTables": [],
        "syncKeyMismatches": [
          {
            "qualifiedTable": "business.users",
            "clientSyncKeyColumns": ["id"],
            "serverSyncKeyColumns": ["user_id"]
          }
        ]
      }
    },
    {
      "name": "schema-mismatch",
      "localSpecs": [
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]}
      ],
      "advertised": [
        {"schema": "public", "table": "users", "sync_key_columns": ["id"]}
      ],
      "expected": {
        "kind": "mismatch",
        "serverOnlyTables": ["public.users"],
        "clientOnlyTables": ["business.users"],
        "syncKeyMismatches": []
      }
    },
    {
      "name": "missing-metadata",
      "localSpecs": [
        {"schema": "business", "table": "users", "sync_key_columns": ["id"]}
      ],
      "expected": {"kind": "invalid"}
