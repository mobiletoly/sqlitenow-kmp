      "committedBundleRowsResponse": {
        "bundle_seq": 1,
        "source_id": "source-fixture",
        "source_bundle_id": 1,
        "row_count": 1,
        "bundle_hash": "fixture-hash",
        "rows": [
          {
            "schema": "main",
            "table": "users",
            "key": {
              "id": "user-1"
            },
            "op": "INSERT",
            "row_version": 1,
            "payload": {
              "id": "user-1",
              "name": "Ada"
