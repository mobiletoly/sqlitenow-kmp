                  "name": "Ada"
                }
              }
            ]
          },
          {
            "bundle_seq": 2,
            "source_id": "remote-source",
            "source_bundle_id": 2,
            "rows": [
              {
                "schema": "main",
                "table": "users",
                "key": {
                  "id": "user-1"
                },
                "op": "DELETE",
                "row_version": 2,
                "payload": null
              }
            ]
          }
        ],
        "has_more": false
      },
      "expectedFinalState": {
        "lastBundleSeqSeen": 2,
        "usersRowCount": 0,
        "rowStateDeleted": 1,
        "dirtyRowCount": 0
      }
    },
