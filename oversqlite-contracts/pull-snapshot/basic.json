{
  "formatVersion": 1,
  "cases": [
    {
      "name": "populated-adoption-baseline",
      "afterBundleSeq": 0,
      "pullResponse": {
        "stable_bundle_seq": 1,
        "bundles": [
          {
            "bundle_seq": 1,
            "source_id": "oversync-adoption:00000000-0000-4000-8000-000000000001",
            "source_bundle_id": 1,
            "rows": [
              {
                "schema": "main",
                "table": "users",
                "key": {
                  "id": "adopted-user-1"
                },
                "op": "INSERT",
                "row_version": 1,
                "payload": {
                  "id": "adopted-user-1",
                  "name": "Adopted"
                }
              }
            ]
          }
        ],
        "has_more": false
      },
      "snapshotSession": {
        "snapshot_id": "snapshot-adoption-1",
        "snapshot_bundle_seq": 1,
        "row_count": 1,
        "byte_count": 0,
        "expires_at": "2099-01-01T00:00:00Z"
      },
      "snapshotChunkResponse": {
        "snapshot_id": "snapshot-adoption-1",
        "snapshot_bundle_seq": 1,
        "rows": [
          {
            "schema": "main",
            "table": "users",
            "key": {
              "id": "adopted-user-1"
            },
            "row_version": 1,
            "payload": {
              "id": "adopted-user-1",
              "name": "Adopted"
            }
          }
        ],
        "next_row_ordinal": 1,
        "has_more": false
      },
      "expectedFinalState": {
        "lastBundleSeqSeen": 1,
        "usersRowCount": 1,
        "rowStateDeleted": 0,
        "dirtyRowCount": 0
      }
    },
    {
      "name": "incremental-insert-delete",
      "afterBundleSeq": 0,
      "pullResponse": {
        "stable_bundle_seq": 2,
